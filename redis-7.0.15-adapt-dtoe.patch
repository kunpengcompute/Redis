+static int checkIpv4(const char *ip)
+{
+    if (ip == NULL) {
+        return 0;
+    }
+    int num, dots = 0;
+    const char *p = ip;
+    while (*p) {
+        if (!isdigit(*p)) {
+            return 0;
+        }
+        num = 0;
+        int len = 0;
+        while (*p && isdigit(*p)) {
+            num = num * 10 + (*p - '0');
+            len++;
+            p++;
+        }
+        if (len == 0 || len > 3) {
+            return 0;
+        }
+        if (num < 0  || num > 255) {
+            return 0;
+        }
+        if (len > 1 && ip[strlen(ip) - strlen(p) -len] == '0') {
+            return 0;
+        }
+        if (*p == '.') {
+            dots++;
+            p++;
+        } else if (*p != '\0') {
+            return 0;
+        }
+    }
+    return dots == 3;
+}
+
+static int isValidIpv4(char *ip, const char **err) 
+{
+    if ((ip[0] == '\0') || (ip[0] != '\0' && checkIpv4(ip))) {
+        return 1;
+    }
+    *err = "invalid ipv4 address, please check dtoe-ip value in the redis.conf";
+    return 0;
+}
