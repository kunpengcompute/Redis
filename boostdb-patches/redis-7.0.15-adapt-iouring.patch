+int callback_before_common(client *c, ssize_t *nwritten) {
+    if (*nwritten <= 0) return C_ERR;
+    if (getClientType(c) == CLIENT_TYPE_SLAVE) {
+        serverAssert(c->bufpos == 0 && listLength(c->reply) == 0);
+
+        replBufBlock *o = listNodeValue(c->ref_repl_buf_node);
+        serverAssert(o->used >= c->ref_block_pos);
+        /* Send current block if it is not fully sent. */
+        if (o->used > c->ref_block_pos) {
+            c->ref_block_pos += *nwritten;
+        }
+
+        /* If we fully sent the object on head, go to the next one. */
+        listNode *next = listNextNode(c->ref_repl_buf_node);
+        if (next && c->ref_block_pos == o->used) {
+            o->refcount--;
+            ((replBufBlock *)(listNodeValue(next)))->refcount++;
+            c->ref_repl_buf_node = next;
+            c->ref_block_pos = 0;
+            incrementalTrimReplicationBacklog(REPL_BACKLOG_TRIM_BLOCKS_PER_CALL);
+        }
+        return C_OK;
+    }
+    return C_OK;
+}
+
+void callback_after_common(client *c, ssize_t *nwritten, ssize_t totwritten) {
+    if (getClientType(c) == CLIENT_TYPE_SLAVE) {
+        atomicIncr(server.stat_net_repl_output_bytes, totwritten);
+    } else {
+        atomicIncr(server.stat_net_output_bytes, totwritten);
+    }
+
+    if (*nwritten == -1 && errno != EAGAIN) {
+        c->conn->last_errno = errno;
+        if (errno != EINTR && connGetState(c->conn) == CONN_STATE_CONNECTED) {
+            c->conn->state = CONN_STATE_ERROR;
+            serverLog(LL_WARNING, "[Euler]Error writing to client: %s", connGetLastError(c->conn));
+            freeClientAsync(c);
+            return;
+        }
+    }
+
+    if (totwritten > 0) {
+        /* For clients representing masters we don't count sending data
+         * as an interaction, since we always send REPLCONF ACK commands
+         * that take some time to just fill the socket output buffer.
+         * We just rely on data / pings received for timeout detection. */
+        if (!(c->flags & CLIENT_MASTER)) c->lastinteraction = server.unixtime;
+    }
+
+    if (!clientHasPendingReplies(c)) {
+        c->sentlen = 0;
+
+        /* Close connection after entire reply has been sent. */
+        if (c->flags & CLIENT_CLOSE_AFTER_REPLY) {
+            freeClientAsync(c);
+            return;
+        }
+    } else {
+        if (*nwritten == -1 && errno == EAGAIN) {
+            /* Wait for kernel epollout event if tcp write buffer is full */
+            installClientWriteHandler(c);
+        } else {
+            writeToClient(c, 0);
+        }
+    }
+
+    if (io_threads_op == IO_THREADS_OP_IDLE)
+        updateClientMemUsageAndBucket(c);
+}
+
+void handle_writev_callback(client *c, ssize_t *nwritten) {
+    if (*nwritten <= 0) return;
+    /* Locate the new node which has leftover data and
+     * release all nodes in front of it. */
+    ssize_t remaining = *nwritten;
+    listIter iter;
+    listNode *next;
+    clientReplyBlock *o;
+    if (c->bufpos > 0) { /* deal with static reply buffer first. */
+        int buf_len = c->bufpos - c->sentlen;
+        c->sentlen += remaining;
+        /* If the buffer was sent, set bufpos to zero to continue with
+         * the remainder of the reply. */
+        if (remaining >= buf_len) {
+            c->bufpos = 0;
+            c->sentlen = 0;
+
+        }
+        remaining -= buf_len;
+    }
+    listRewind(c->reply, &iter);
+    while (remaining > 0) {
+        next = listNext(&iter);
+        o = listNodeValue(next);
+        if (remaining < (ssize_t)(o->used - c->sentlen)) {
+            c->sentlen += remaining;
+            break;
+        }
+        remaining -= (ssize_t)(o->used - c->sentlen);
+        c->reply_bytes -= o->size;
+        listDelNode(c->reply, next);
+        c->sentlen = 0;
+    }
+}
+
+void handle_write_callback(client *c, ssize_t *nwritten) {
+    if (c->bufpos > 0) {
+        if (*nwritten <= 0) return;
+        c->sentlen += *nwritten;
+        /* If the buffer was sent, set bufpos to zero to continue with
+        * the remainder of the reply. */
+        if ((int)c->sentlen == c->bufpos) {
+            c->bufpos = 0;
+            c->sentlen = 0;
+        }
+    }
+}
+
+void write_callback_common(client *c, int ret, handle_callback_t handle_callback) {
+    atomicIncr(server.stat_total_writes_processed, 1);
+    ssize_t nwritten = 0, totwritten = 0;
+    c->flags &= ~CLIENT_ASYNC;
+    while (nwritten == 0) {
+        nwritten = ret;
+        if (ret == C_ERR) break;
+        callback_before_common(c, &nwritten);
+        handle_callback(c, &nwritten);
+        totwritten += nwritten;
+        if (totwritten > NET_MAX_WRITES_PER_EVENT &&
+            (server.maxmemory == 0 ||
+             zmalloc_used_memory() < server.maxmemory) &&
+            !(c->flags & CLIENT_SLAVE)) break;
+    }
+    callback_after_common(c, &nwritten, totwritten);
+}
+
+void writeCallback(int ret, __attribute__((unused))void *buf, __attribute__((unused))int len, void *para1, __attribute__((unused))void *para2, __attribute__((unused))void *para3) {
+    client *c = (client*) para1;
+    write_callback_common(c, ret, handle_write_callback);
+}
+
+void writevCallback(int ret, __attribute__((unused))struct iovec *iov, __attribute__((unused))int iovcnt, void *para1, __attribute__((unused))void *para2, __attribute__((unused))void *para3) {
+    client *c = (client*) para1;
+    write_callback_common(c, ret, handle_writev_callback);
+}
+
+__attribute__((constructor)) void registWriteCallback() {register_write_callback(writeCallback);}
+__attribute__((constructor)) void registWritevCallback() {register_writev_callback(writevCallback);}
+
 /* This function should be called from _writeToClient when the reply list is not empty,
  * it gathers the scattered buffers from reply list and sends them away with connWritev.
  * If we write successfully, it returns C_OK, otherwise, C_ERR is returned,
  * and 'nwritten' is an output parameter, it means how many bytes server write
  * to client. */
+static int _writevToClientAsync(client *c, ssize_t *nwritten) {
+    struct iovec iov[IOV_MAX];
+    int iovcnt = 0;
+    size_t iov_bytes_len = 0;
+    /* If the static reply buffer is not empty, 
+     * add it to the iov array for writev() as well. */
+    if (c->bufpos > 0) {
+        iov[iovcnt].iov_base = c->buf + c->sentlen;
+        iov[iovcnt].iov_len = c->bufpos - c->sentlen;
+        iov_bytes_len += iov[iovcnt++].iov_len;
+    }
+    /* The first node of reply list might be incomplete from the last call,
+     * thus it needs to be calibrated to get the actual data address and length. */
+    size_t offset = c->bufpos > 0 ? 0 : c->sentlen;
+    listIter iter;
+    listNode *next;
+    clientReplyBlock *o;
+    listRewind(c->reply, &iter);
+    while ((next = listNext(&iter)) && iovcnt < IOV_MAX && iov_bytes_len < NET_MAX_WRITES_PER_EVENT) {
+        o = listNodeValue(next);
+        if (o->used == 0) { /* empty node, just release it and skip. */
+            c->reply_bytes -= o->size;
+            listDelNode(c->reply, next);
+            offset = 0;
+            continue;
+        }
+
+        iov[iovcnt].iov_base = o->buf + offset;
+        iov[iovcnt].iov_len = o->used - offset;
+        iov_bytes_len += iov[iovcnt++].iov_len;
+        offset = 0;
+    }
+    if (iovcnt == 0) return C_OK;
+    if (!isEvictionProcRunning) {
+        int ret = writev_async(c->conn->fd, iov, iovcnt, c, NULL, NULL);
+        if (ret > 0) {
+            c->flags |= CLIENT_ASYNC;
+            return C_OK;
+        }
+    }
+    *nwritten = connWritev(c->conn, iov, iovcnt);
+    if (*nwritten <= 0) return C_ERR;
+
+    /* Locate the new node which has leftover data and
+     * release all nodes in front of it. */
+    ssize_t remaining = *nwritten;
+    if (c->bufpos > 0) { /* deal with static reply buffer first. */
+        int buf_len = c->bufpos - c->sentlen;
+        c->sentlen += remaining;
+        /* If the buffer was sent, set bufpos to zero to continue with
+         * the remainder of the reply. */
+        if (remaining >= buf_len) {
+            c->bufpos = 0;
+            c->sentlen = 0;
+        }
+        remaining -= buf_len;
+    }
+    listRewind(c->reply, &iter);
+    while (remaining > 0) {
+        next = listNext(&iter);
+        o = listNodeValue(next);
+        if (remaining < (ssize_t)(o->used - c->sentlen)) {
+            c->sentlen += remaining;
+            break;
+        }
+        remaining -= (ssize_t)(o->used - c->sentlen);
+        c->reply_bytes -= o->size;
+        listDelNode(c->reply, next);
+        c->sentlen = 0;
+    }
+
+    return C_OK;
+}
+
+/* This function does actual writing output buffers to different types of
+ * clients, it is called by writeToClient.
+ * If we write successfully, it returns C_OK, otherwise, C_ERR is returned,
+ * and 'nwritten' is an output parameter, it means how many bytes server write
+ * to client. */
+int _writeToClientAsync(client *c, ssize_t *nwritten) {
+    *nwritten = 0;
+    if (getClientType(c) == CLIENT_TYPE_SLAVE) {
+        serverAssert(c->bufpos == 0 && listLength(c->reply) == 0);
+
+        replBufBlock *o = listNodeValue(c->ref_repl_buf_node);
+        serverAssert(o->used >= c->ref_block_pos);
+        /* Send current block if it is not fully sent. */
+        if (o->used > c->ref_block_pos) {
+            int ret = write_async(c->conn->fd, o->buf+c->ref_block_pos,
+                                  o->used-c->ref_block_pos, c, NULL, NULL);
+            if (ret > 0) {
+                c->flags |= CLIENT_ASYNC;
+                return C_OK;
+            }
+            *nwritten = connWrite(c->conn, o->buf+c->ref_block_pos,
+                                  o->used-c->ref_block_pos);
+            if (*nwritten <= 0) return C_ERR;
+            c->ref_block_pos += *nwritten;
+        }
+
+        /* If we fully sent the object on head, go to the next one. */
+        listNode *next = listNextNode(c->ref_repl_buf_node);
+        if (next && c->ref_block_pos == o->used) {
+            o->refcount--;
+            ((replBufBlock *)(listNodeValue(next)))->refcount++;
+            c->ref_repl_buf_node = next;
+            c->ref_block_pos = 0;
+            incrementalTrimReplicationBacklog(REPL_BACKLOG_TRIM_BLOCKS_PER_CALL);
+        }
+        return C_OK;
+    }
+
+    /* When the reply list is not empty, it's better to use writev to save us some
+     * system calls and TCP packets. */
+    if (listLength(c->reply) > 0) {
+        int ret = _writevToClientAsync(c, nwritten);
+        if (ret == C_OK && (c->flags & CLIENT_ASYNC)) return C_OK;
+        if (ret != C_OK) return ret;
+
+        /* If there are no longer objects in the list, we expect
+         * the count of reply bytes to be exactly zero. */
+        if (listLength(c->reply) == 0)
+            serverAssert(c->reply_bytes == 0);
+    } else if (c->bufpos > 0) {
+        if (!isEvictionProcRunning) {
+            int ret = write_async(c->conn->fd, c->buf + c->sentlen, c->bufpos - c->sentlen, c, NULL, NULL);
+            if (ret > 0) {
+                c->flags |= CLIENT_ASYNC;
+                return C_OK;
+            }
+        }
+        *nwritten = connWrite(c->conn, c->buf + c->sentlen, c->bufpos - c->sentlen);
+        if (*nwritten <= 0) return C_ERR;
+        c->sentlen += *nwritten;
+
+        /* If the buffer was sent, set bufpos to zero to continue with
+         * the remainder of the reply. */
+        if ((int)c->sentlen == c->bufpos) {
+            c->bufpos = 0;
+            c->sentlen = 0;
+        }
+    } 
+
+    return C_OK;
+}
+
 static int _writevToClient(client *c, ssize_t *nwritten) {
+    if (iouring_enable) {
+        return _writevToClientAsync(c, nwritten);
+    }
     struct iovec iov[IOV_MAX];
     int iovcnt = 0;
     size_t iov_bytes_len = 0;
@@ -1894,6 +2196,9 @@ static int _writevToClient(client *c, ssize_t *nwritten) {
  * and 'nwritten' is an output parameter, it means how many bytes server write
  * to client. */
 int _writeToClient(client *c, ssize_t *nwritten) {
+    if (iouring_enable) {
+        return _writeToClientAsync(c, nwritten);
+    }
     *nwritten = 0;
     if (getClientType(c) == CLIENT_TYPE_SLAVE) {
         serverAssert(c->bufpos == 0 && listLength(c->reply) == 0);
@@ -1960,8 +2265,14 @@ int writeToClient(client *c, int handler_installed) {
 
     ssize_t nwritten = 0, totwritten = 0;
 
+    if (c->flags & CLIENT_ASYNC)
+        return C_OK;
+
     while(clientHasPendingReplies(c)) {
         int ret = _writeToClient(c, &nwritten);
+        /* Always return ERR to avoid installing write handler in handleClientsWithPendingWrites() */
+        if (c->flags & CLIENT_ASYNC) return C_ERR;
+
         if (ret == C_ERR) break;
         totwritten += nwritten;
         /* Note that we avoid to send more than NET_MAX_WRITES_PER_EVENT
